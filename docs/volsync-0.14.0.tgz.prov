annotations:
  artifacthub.io/changes: |
    - kind: changed
      description: Updated release to build on golang 1.24
    - kind: changed
      description: Syncthing updated to v1.30.0
    - kind: changed
      description: Rclone updated to v1.71.2
    - kind: added
      description: Rclone --checksum, --transfers and --stats parameters can now be overridden by RCLONE_ env vars in the rclone config secret
    - kind: added
      description: addition of moverVolumes for advanced users to allow mounting of secrets or PVCs to their mover pod
